{
  "name": "@ikenxuan/watermark",
  "version": "1.1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikenxuan/watermark.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "napi": {
    "binaryName": "watermark",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "artifacts": "napi artifacts --output-dir artifacts",
    "napi:build": "napi build --platform --release --esm --output-dir dist",
    "napi:build:debug": "napi build --platform --esm --output-dir dist",
    "create-npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish --no-gh-release"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "pkg-pr-new": "^0.0.74",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@ikenxuan/watermark-darwin-arm64": "1.0.11",
    "@ikenxuan/watermark-linux-arm64-gnu": "1.0.11",
    "@ikenxuan/watermark-linux-x64-gnu": "1.0.11",
    "@ikenxuan/watermark-win32-x64-msvc": "1.0.11"
  }
}
